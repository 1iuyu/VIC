{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Debug VIC",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/src/drivers/image/vic_image.exe",
      "stopAtEntry": false,
      "externalConsole": false,

      "args": ["-g"],
      
      "linux": {
        "program": "${workspaceFolder}/src/drivers/image/vic_image.exe",
        "args": ["-g", "./global_param.txt"],
        "cwd": "${workspaceFolder}/samples/data/",
        "MIMode": "gdb",
        "miDebuggerPath": "/usr/bin/gdb"
      },

      "osx": {
        "program": "${workspaceFolder}/src/drivers/image/vic_image.exe",
        "args": ["-g", "./global_param.txt"],
        "cwd": "${workspaceFolder}/samples/data/",
        "MIMode": "lldb"
      }
    }
  ]
}
